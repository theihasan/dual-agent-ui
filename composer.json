{
    "name": "theihasan/dual-agent-ui",
    "description": "Analytics UI for Laravel Nightwatch Dual Agent",
    "keywords": [
        "Ihasan",
        "laravel",
        "dual-agent-ui"
    ],
    "homepage": "https://github.com/ihasan/dual-agent-ui",
    "license": "MIT",
    "authors": [
        {
            "name": "Abul Hassan",
            "email": "imabulhasan99@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^11.0||^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "spatie/laravel-package-tools": "^1.16",
        "theihasan/dual-agent": "^0.1.2"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "phpunit/phpunit": "^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ihasan\\DualAgentUI\\": "src/",
            "Ihasan\\DualAgentUI\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ihasan\\DualAgentUI\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ihasan\\DualAgentUI\\DualAgentUIServiceProvider"
            ],
            "aliases": {
                "DualAgentUI": "Ihasan\\DualAgentUI\\Facades\\DualAgentUI"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
